{%- if cookiecutter.generate_local_otel_stack == "yes" %}
{%- set is_db_project = cookiecutter.project_type in ["fastapi_db", "fastapi_db_agent"] %}
{%- set is_agent_project = cookiecutter.project_type in ["fastapi_agent", "fastapi_db_agent"] %}
{% raw %}{
  "id": null,
  "uid": "{% endraw %}{{ cookiecutter.project_name.lower() }}{% raw %}-overview",
  "title": "{% endraw %}{{ cookiecutter.project_name }}{% raw %} Overview",
  "tags": [{% endraw %}
{% raw %}    "fastapi",{% endraw %}
{%- if is_db_project %}
{% raw %}    "database",{% endraw %}
{%- endif %}
{%- if is_agent_project %}
{% raw %}    "agent",{% endraw %}
{%- endif %}
{% raw %}    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [{% endraw %}
{% raw %}    {
      "type": "row",
      "title": "HTTP Metrics",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "Requests/sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "all"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by Status",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 1},
      "targets": [
        {
          "expr": "sum by (status)(rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by Route",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "sum by (handler)(round(increase(http_requests_total{handler!=\"none\"}[1m])))",
          "legendFormat": "{{handler}}"
        }
      ]
    },{% endraw %}
{%- if is_db_project %}
{% raw %}    {
      "type": "row",
      "title": "Business Metrics",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7}
    },
    {
      "type": "timeseries",
      "title": "Search Queries by Resource",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (resource)(increase(search_queries_total[$__range]))",
          "legendFormat": "{{resource}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Search Queries by Filter Usage",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (has_filters)(increase(search_queries_total[$__range]))",
          "legendFormat": "has_filters={{has_filters}}"
        }
      ]
    },{% endraw %}
{%- endif %}
{%- if is_agent_project %}
{% raw %}    {
      "type": "row",
      "title": "Agent Metrics",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": {% endraw %}
{%- if is_db_project %}14{%- else %}7{%- endif %}{% raw %}}
    },
    {
      "type": "stat",
      "title": "Agent Requests",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": {% endraw %}
{%- if is_db_project %}15{%- else %}8{%- endif %}{% raw %}},
      "targets": [
        {
          "expr": "sum(increase(agent_requests_total[$__range]))",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inflight Agent Requests",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": {% endraw %}
{%- if is_db_project %}15{%- else %}8{%- endif %}{% raw %}},
      "targets": [
        {
          "expr": "agent_inflight_requests",
          "legendFormat": "inflight"
        }
      ]
    },{% endraw %}
{%- endif %}
{%- if cookiecutter.project_type == "fastapi_slim" %}
{% raw %}    {
      "type": "row",
      "title": "Example Metrics (Replace with your actual business metrics)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7}
    },
    {
      "type": "text",
      "title": "Getting Started",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 8},
      "options": {
        "content": {% endraw %}{{
          (
            "# TODO: Add Your Business Metrics\n\n"
            ~ "This dashboard currently only shows infrastructure metrics. "
            ~ "To add your business metrics:\n\n"
            ~ "1. Define your metrics in `app/core/observability/metrics/counters.py` "
            ~ "or `gauges.py`\n"
            ~ "2. Use the `@track_inflight` and `@increment_after` decorators in your code\n"
            ~ "3. Update this dashboard with panels that query your custom metrics\n\n"
            ~ "Example:\n"
            ~ "```python\n"
            ~ "from app.core.observability.metrics import counters\n"
            ~ "from app.core.observability.metrics.primitives import increment_after\n\n"
            ~ "@increment_after(counters.example_operations_total.labels('my_operation'))\n"
            ~ "async def my_function():\n"
            ~ "    pass\n"
            ~ "```\n\n"
            ~ "Then add a panel with query: `increase(example_operations_total[$__range])`"
          ) | tojson
        }}{% raw %},
        "mode": "markdown"
      }
    },{% endraw %}
{%- endif %}
{%- if cookiecutter.use_otel_observability == "yes" %}
{% raw %}    {
      "type": "row",
      "title": "Logs & Traces",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": {% endraw %}
{%- if is_db_project and is_agent_project %}21{%- else %}14{%- endif %}{% raw %}}
    },
    {
      "type": "logs",
      "title": "Application Logs",
      "gridPos": {"h": 14, "w": 14, "x": 0, "y": {% endraw %}
{%- if is_db_project and is_agent_project %}22{%- else %}15{%- endif %}{% raw %}},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{compose_service=\"{% endraw %}{{ cookiecutter.project_name.lower() }}{% raw %}-app\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": false,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      }
    },
    {
      "type": "table",
      "title": "Traces",
      "gridPos": {"h": 14, "w": 10, "x": 14, "y": {% endraw %}
{%- if is_db_project and is_agent_project %}22{%- else %}15{%- endif %}{% raw %}},
      "datasource": {"type": "tempo", "uid": "tempo"},
      "fieldConfig": {"defaults": {"custom": {}}, "overrides": []},
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "legend": {"showLegend": false},
        "footer": {"show": false, "reducer": ["sum"], "fields": "", "countRows": false}
      },
      "targets": [
        {
          "datasource": {"type": "tempo", "uid": "tempo"},
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": ["{% endraw %}{{ cookiecutter.project_name }}{% raw %}"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ]
    }{% endraw %}
{%- endif %}
{% raw %}  ]
}{% endraw %}
{%- endif %}
